set encoding=utf-8
set nobackup
set noswapfile
set autoread
set hidden
set showcmd

set number
set cursorline
"set cursorcolumn
set virtualedit=onemore
set smartindent
set visualbell
set showmatch
set statusline=2
set wildmode=list:longest

nnoremap j gj
nnoremap k gk

set expandtab
set tabstop=4
set shiftwidth=4
set autoindent

syntax on

set nohlsearch

set list
set listchars=tab:>.,trail:_,eol:↲,extends:>,precedes:<,nbsp:%

set nrformats=

set wildmenu
set wildmode=full

set history=200

set nocompatible
filetype plugin on
