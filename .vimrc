set encoding=utf-8
set nobackup
set noswapfile
set autoread
set hidden

set number
set expandtab
set tabstop=4
set shiftwidth=4
set autoindent
set smartindent

syntax on

set nohlsearch
set cursorline

set list
set listchars=tab:>.,trail:_,eol:↲,extends:>,precedes:<,nbsp:%

set nrformats=

set wildmenu
set wildmode=full

set history=200

set nocompatible
filetype plugin on
